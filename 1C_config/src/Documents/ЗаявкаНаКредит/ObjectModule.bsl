Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
    
    Дата = ТекущаяДата();
    Статус = Перечисления.СтатусыЗаявок.НаРассмотрении;
    
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
    
    // Фиксируем пометку на удаление
    Если ПометкаУдаления И Не ЭтоНовый() И Не Ссылка.ПометкаУдаления Тогда
        Комментарий = "Заявка №" + Номер + " помечена на удаление";
        Журналирование.ЗаписатьДействие(Ссылка, "Пометка на удаление", Комментарий);
    КонецЕсли;
    
    // Фиксируем снятие пометки 
    Если Не ПометкаУдаления И Не ЭтоНовый() И Ссылка.ПометкаУдаления Тогда
        Комментарий = "Снята пометка удаления с заявки №" + Номер;
        Журналирование.ЗаписатьДействие(Ссылка, "Снятие пометки на удаление", Комментарий);
    КонецЕсли;
    
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
    
    // Проверка статуса
    Если Статус <> Перечисления.СтатусыЗаявок.Выдано Тогда
        Комментарий = "Заявка №" + Номер + " статус: " + Статус;
        Журналирование.ЗаписатьДействие(Ссылка, "Изменение статуса", Комментарий);
        Возврат;
    КонецЕсли;
    
    // Создаем новый счет для кредита
    НовыйСчет = Справочники.БанковскиеСчета.СоздатьЭлемент();
    НовыйСчет.Владелец = Клиент;
    НовыйСчет.Наименование = "Кредитный счет по заявке №" + Номер;
    НовыйСчет.ТипСчета = Справочники.ТипыСчетов.НайтиПоНаименованию("Кредитный");
    НовыйСчет.Валюта = Справочники.Валюты.НайтиПоКоду("643");
    НовыйСчет.Открыт = Истина;
    НовыйСчет.ДатаОткрытия = Дата;
    НовыйСчет.Записать();
    
    // Зачисляем сумму кредита
    Движения.ОстаткиНаСчетах.Очистить();
    
    Движение = Движения.ОстаткиНаСчетах.Добавить();
    Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
    Движение.Период = Дата;
    Движение.Счет = НовыйСчет.Ссылка;
    Движение.Сумма = СуммаКредита;
    
    Движения.ОстаткиНаСчетах.Записывать = Истина;
    
    // Запись в журнал аудит о выдаче
    Комментарий = "ВЫДАЧА КРЕДИТА №" + Номер + " на сумму " + СуммаКредита + " руб. клиенту " + Клиент;
    Журналирование.ЗаписатьДействие(Ссылка, "Выдача кредита", Комментарий);
    
КонецПроцедуры

Процедура ОбработкаУдаления(Отказ, РежимУдаления)
    
    // Запись в аудит о физическом удалении 
	Комментарий = "Заявка №" + Номер + " физически удалена из базы";
    Журналирование.ЗаписатьДействие(Ссылка, "Физическое удаление", Комментарий);
    
КонецПроцедуры