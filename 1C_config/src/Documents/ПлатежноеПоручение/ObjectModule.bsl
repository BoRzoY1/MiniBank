Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
    
    Дата = ТекущаяДата();
    
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
    
    // Фиксируем пометку на удаление 
	Если ПометкаУдаления И Не ЭтоНовый() И Не Ссылка.ПометкаУдаления Тогда
        Комментарий = "Платеж №" + Номер + " помечен на удаление";
        Журналирование.ЗаписатьДействие(Ссылка, "Пометка на удаление", Комментарий);
    КонецЕсли;
    
    // Фиксируем снятие пометки 
    Если Не ПометкаУдаления И Не ЭтоНовый() И Ссылка.ПометкаУдаления Тогда
        Комментарий = "Снята пометка удаления с платежа №" + Номер;
        Журналирование.ЗаписатьДействие(Ссылка, "Снятие пометки на удаление", Комментарий);
    КонецЕсли;
    
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
    
    // счета не должны совпадать
    Если СчетОтправителя = СчетПолучателя Тогда
        Отказ = Истина;
        Сообщить("Ошибка: счет отправителя и получателя должны быть разными");
        Возврат;
    КонецЕсли;
    

    Движения.ОстаткиНаСчетах.Очистить();
    
    Движение = Движения.ОстаткиНаСчетах.Добавить();
    Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
    Движение.Период = Дата;
    Движение.Счет = СчетОтправителя;
    Движение.Сумма = Сумма;
    
    Движение = Движения.ОстаткиНаСчетах.Добавить();
    Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
    Движение.Период = Дата;
    Движение.Счет = СчетПолучателя;
    Движение.Сумма = Сумма;
    
    Движения.ОстаткиНаСчетах.Записывать = Истина;
    
    // заполнено ли поле ДокументОснование
    Если ЗначениеЗаполнено(ДокументОснование) Тогда
        
        Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.СчетНаОплату") Тогда
            СчетОбъект = ДокументОснование.ПолучитьОбъект();
            СчетОбъект.Статус = Перечисления.СтатусыПлатежа.Исполнен;
            СчетОбъект.Записать();
        КонецЕсли;
        
        Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаявкаНаРасходДС") Тогда
            ЗаявкаОбъект = ДокументОснование.ПолучитьОбъект();
            ЗаявкаОбъект.Статус = Перечисления.СтатусыПлатежа.Исполнен;
            ЗаявкаОбъект.Записать();
        КонецЕсли;
        
    КонецЕсли;
    
    // Запись в журнал аудита
    Комментарий = "Платеж №" + Номер + " на сумму " + Сумма + " руб.";
    Журналирование.ЗаписатьДействие(Ссылка, "Проведение", Комментарий);
    
КонецПроцедуры

Процедура ОбработкаУдаления(Отказ, РежимУдаления)
    
    // Запись в аудит о физическом удалении
	Комментарий = "Платеж №" + Номер + " физически удален из базы";
    Журналирование.ЗаписатьДействие(Ссылка, "Физическое удаление", Комментарий);
    
КонецПроцедуры

