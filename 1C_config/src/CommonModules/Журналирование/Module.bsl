Процедура ЗаписатьДействие(ОбъектСсылка, Действие, Комментарий = "") Экспорт
    
    ИмяПользователя = ПолучитьИмяПользователя();
    
    Запись = РегистрыСведений.ЖурналАудита.СоздатьМенеджерЗаписи();
    
    Запись.Период = ТекущаяДата();
    Запись.ОбъектМетаданных = Строка(ТипЗнч(ОбъектСсылка));
    Запись.КлючОбъекта = Строка(ОбъектСсылка.УникальныйИдентификатор());
    Запись.Действие = Действие;
    Запись.ПредставлениеОбъекта = Строка(ОбъектСсылка);
    Запись.Комментарий = Комментарий;
    Запись.Пользователь = ИмяПользователя;
    Запись.IPАдрес = "192.168.1.100";
    Запись.Сеанс = "83d4b9a0-1d6c-11f1-8eb3-00a750708120";
    
    Попытка
        Запись.Записать();
	Исключение
		
    КонецПопытки;
    
КонецПроцедуры

Функция ПолучитьИмяПользователя()
    
    // Пробуем получить из параметров сеанса
    Попытка
        ИмяПользователя = ПараметрыСеанса.ИмяПользователя;
        Если ИмяПользователя <> Неопределено И ИмяПользователя <> "" Тогда
            Возврат ИмяПользователя;
        КонецЕсли;
    Исключение

    КонецПопытки;
    
    // Пробуем через пользователей информационной базы
    Попытка
        ТекПользователь = ПользователиИнформационнойБазы.ТекущийПользователь();
        Если ТекПользователь <> Неопределено Тогда
            Возврат ТекПользователь.Имя;
        КонецЕсли;
    Исключение

    КонецПопытки;
    
    // Запасной вариант
    Возврат "Пользователь";
    
КонецФункции